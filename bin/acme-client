// main program
(async function main () {
  const debuglog = await import('../server/debuglog.mjs').then(m => m.default);
  const settings = await import('../server/settings/index.mjs').then(m => m.default);
  const debug = debuglog('debug:acme');
  debug('ACME client');


})();

