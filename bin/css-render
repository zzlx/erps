#!/usr/bin/env node
/**
 * *****************************************************************************
 * 
 * Scss编译生成CSS
 *
 * 用于从src/scss目录生成css文件
 *
 * [参考文档](../node_modules/sass/README.md)
 * [node-sass](https://github.com/sass/node-sass)
 * *****************************************************************************
 */

const sass = require('sass');

// 配置项目
let scssFile = null;
let format = 'compressed'; // 使用压缩模式

const argvs = process.argv.slice(2);

for (let i = 0; i < argvs.length; i++) {
  const argv = argvs[i];

  if (/^-/.test(argv) === false) { scssFile = argv; continue; }

  switch (arg) {
    case '--expanded':
      format = 'expanded';
      break;
    case '--compressed':
      format = 'compressed';
      break;
    default:
      process.stderr.write(`${arg} is not supported.`);
  }
}

// render css 
scssFile && sass.render({ 
  file: scssFile, 
  outputStyle: format, 
}, (err, result) => { 
  if (err) return process.stderr.write(err);
  process.stdout.write(result.css);
});
