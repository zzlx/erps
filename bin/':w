#!/usr/bin/env node

/**
 * *****************************************************************************
 *
 * 读取目录文件,创建索引文件index.mjs
 *
 * 遍历文件并读入模块对象中
 * *****************************************************************************
 */

const fs = require('fs');
const path = require('path');

const argvs = Array.prototype.slice.call(process.argv, 2);
const dir = argvs[0]; 

if (dir == null) {
  console.error('Error: 请提供一个目录作为参数');
  process.exit();
}

fs.promises.readdir(dir, { encoding: 'utf8', withFileTypes: true }).then(files => {
  console.log(`/**
 * *****************************************************************************
 *
 * Index模块
 *
 * 由index-path-module工具自动生成
 * *****************************************************************************
 */
    `);

  files.map(file => {
    if (file.isDirectory()) {
      console.log(`export * from './${file.name}/index.mjs';`);
    } else if (file.isFile()) { 
      if (file.name === 'index.mjs') return;
      if (/^\./.test(file.name)) return;
      if (!/.mjs$/.test(file.name)) return;
      console.log(`export { ${path.basename(file.name, '.mjs')} } from './${file.name}';`);
    }
  });
});
