#!/usr/bin/env node --no-warnings --experimental-json-modules
/**
 * *****************************************************************************
 *
 * Dev server
 *
 * *****************************************************************************
 */

const cp = require('child_process');
const crypto = require('crypto');
const EventEmitter = require('events'); 
const fs = require('fs');
const path = require('path');

process.env.NODE_ENV = 'development'; // set development environment
process.env.NODE_DEBUG = 'debug*';

let sub_process = null;

const APP_ROOT = path.dirname(__dirname);
const Args = [
  '--experimental-json-modules',
  path.join(APP_ROOT, 'src', 'erpsd.mjs'),
];

options = {
  //cwd: APP_ROOT,
  env: process.env,
  detached: process.env.FORK ? true : false, // to dtach subprocess from main process
  stdio: process.env.FORK ? ['ignore', log, log] : [0, 1, 2], 
};

sub_process = cp.spawn('node', Args.concat(['--start']), options);

const interval = setInterval(() => {

  readdir(path.join(APP_ROOT, 'src')).then((changed) => {
		if (changed) {
			console.log('Change has been detected.');
			sub_process = cp.spawn('node', Args.concat(['--restart']), options);
		}
  });
}, 1500);

// clear interval befor exit
process.on('beforeExit', () => { 
  clearInterval(interval); 
});

/**
 * 监控文件夹内容变动,变动时出发事件
 *
 */

class PathWatcher extends EventEmitter {
  constructor() {
  }

}


function shasum (filePath) {
  return new Promise((resolve, reject) => {
    fs.createReadStream(filePath).pipe(crypto.createHash('sha1')).on('readable', function () {
      let chunk;
      while (chunk = this.read()) {
        const sha1 = chunk.toString('hex');
        resolve(sha1);
      }
    });
 });
}

const storeMap = new Map();

function readdir (dir) {
  return fs.promises.readdir(dir, {withFileTypes: true}).then(async files => {
		let hasChanged = false;

		for (let file of files) {
      if (/~$/.test(file)) continue;

      if (file.isFile()) {
        const filePath = path.join(dir, file.name);

        hasChanged = await shasum(filePath).then(c => {
					let changed = false;
          if (storeMap.has(filePath) && storeMap.get(filePath) !== c) {
						changed = true;
          }

          storeMap.set(filePath, c);

					return changed;
        });

				if (hasChanged) break;
      }

      if (file.isDirectory()) hasChanged = await readdir(path.join(dir, file.name));
    }

		return hasChanged;
  }).catch(err => {
    if (err.code === 'ENOENT') {
      const filePath = err.path;
    }
  });
}
