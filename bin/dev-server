#!/usr/bin/env node
/**
 * *****************************************************************************
 *
 * Dev server
 *
 * watch resource code
 *
 * *****************************************************************************
 */

const cp = require('child_process');
const crypto = require('crypto');
const EventEmitter = require('events'); 
const fs = require('fs');
const path = require('path');

process.env.NODE_ENV = 'development'; // set development environment
process.env.NODE_DEBUG = 'debug*';

let sub_process = null;

const APP_ROOT = path.dirname(__dirname);
const Args = [
  '--trace-warnings',
  '--experimental_top_level_await',
  '--experimental-json-modules',
  path.join(APP_ROOT, 'bin', 'erpsd.mjs'),
];

options = {
  //cwd: APP_ROOT,
  env: process.env,
  detached: true,
  stdio: process.env.FORK ? ['ignore', 1, 2] : [0, 1, 2], 
};


sub_process = cp.spawn('node', Args.concat(['--start']), options);

const clearInterval = setInterval(() => {
  const changed = readdir(path.join(APP_ROOT, 'src'));
	if (changed) {
		sub_process = cp.spawn('node', Args.concat(['--restart']), options);
	}

}, 1500);

process.on('uncaughtException', (err, origin) => {
  console.log(err);
});

// clear interval befor exit
process.on('beforeExit', () => { 
  //clearInterval();
});

let sigintCount = 0; // SIGINT计数器
process.on('SIGINT', (code) => {
  if (sigintCount >= 1) {
    process.exit();
  }
  sigintCount++;
});

process.on('exit', () => {
  console.log('******************************************');
  console.log('Dev server is exit.');
  console.log('******************************************');
});

process.nextTick(() => {
  console.log('开始执行开发服务程序...');
});

const storeMap = new Map();

function readdir (dir) {
	let hasChanged = false;
  const files = fs.readdirSync(dir, {withFileTypes: true});

	for (let file of files) {
    // 2 conditions
    // condition1: file is a file
    if (file.isFile()) { 
      const filePath = path.join(dir, file.name);
      if (!fs.existsSync(filePath)) continue;

      const content = fs.readFileSync(filePath, 'utf8');
      const sha1 = crypto.createHash('sha1').update(content).digest('hex');

      if (storeMap.has(filePath) && storeMap.get(filePath) !== sha1) {
        console.log(filePath, ' has been changed.');
        hasChanged = true;
      }

      // store sha1
      storeMap.set(filePath, sha1);
    }

    // condition2: file is a directory
    if (file.isDirectory()) {
      hasChanged = readdir(path.join(dir, file.name));
    }

    if (hasChanged) break;
  }

  return hasChanged;
}
