#!/bin/sh

# 获取代码库根目录位置
APP_WORK_TREE=$(dirname $(cd $(dirname $0); pwd))

if [ ! -d "$APP_WORK_TREE/.git" ]; then
  echo "请确认代码库已初始化"
  return 1
fi

# 获取命令行参数 
# $@ 表示所有参数, $n 表示第n个参数
for i
do
case "$i" in
-m*) MESSAGE=$(expr $i + 1);;
-h*) RUN="true"; cat <<EOF
Usage: auto-commit [options]
  -m 提交说明
  -h 帮助
EOF
;;
esac
done

_utc_date () {
  date -u "+%Y-%m-%d %H:%M:%S"
}

_date_serial_number () {
  date "+%Y%m%d"
}

_commit_and_push () {
  git -C $APP_WORK_TREE add -A .
  git -C $APP_WORK_TREE commit -m "$(date "+%Y%m%d")_自动化提交"
  echo "$(_utc_date) 自动化提交完成 $MESSAGE"
  return 0;
}

# 执行提交任务
_commit_and_push
