{
  "name": "erps",
  "version": "1.0.0",
  "description": "A ERP system platform, writen by Node.js.",
	"main": "server/main.mjs",
  "scripts": {
    "dev": "bin/starter.mjs bin/httpd.mjs --restart --paths=bin,server,src",
    "install:vimrc": "ln -s -f $(pwd)/.vimrc ~/.vimrc ",
    "restart": "bin/httpd.mjs --restart",
    "start": "bin/httpd.mjs --start",
    "stop": "bin/httpd.mjs --stop"
  },
  "private": true,
  "dependencies": {
    "gray-matter": "^4.0.2",
    "htmlparser2": "^5.0.0",
    "chart": "^0.1.2",
    "d3": "^5.9.7",
    "jsbarcode": "^3.11.0",
    "mongodb": "^3.4.0",
    "mysql": "^2.15.0",
    "node-sass": "^4.13.0",
    "qrcode": "^1.4.2",
    "react": "^16.13.1",
    "react-dom": "^16.13.1",
    "remarkable": "^1.7.1",
    "tedious": "^9.2.1",
    "xlsx": "^0.14.5"
  }
}
