{
  "name": "erps",
  "description": "A platform of ERP service system.",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "install:vimrc": "ln -sf $(pwd)/src/vim/vimrc ~/.vimrc ",
    "commit": "bin/tools.sh --commit",
    "version": "bin/tools.sh --version",
    "dev": "bin/auto-restart.mjs bin/erps.mjs --restart --paths=bin,server,src,public/utils",
    "start": "bin/erps.mjs --start",
    "stop": "bin/erps.mjs --stop"
  },
  "dependencies": {
    "@babel/polyfill": "^7.12.1",
    "chart": "^0.1.2",
    "d3": "^5.9.7",
    "gray-matter": "^4.0.2",
    "htmlparser2": "^5.0.0",
    "jsbarcode": "^3.11.0",
    "mongodb": "^3.4.0",
    "mysql": "^2.15.0",
    "node-sass": "^4.13.0",
    "qrcode": "^1.4.2",
    "react": "^17.0.1",
    "react-dom": "^17.0.1",
    "remarkable": "^1.7.1",
    "socket.io": "^2.3.0",
    "tedious": "^9.2.1",
    "xlsx": "^0.14.5"
  }
